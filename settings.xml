<?xml version="1.0" encoding="UTF-8"?>
<settings xmlns="http://maven.apache.org/SETTINGS/1.0.0"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://maven.apache.org/SETTINGS/1.0.0
                      https://maven.apache.org/xsd/settings-1.0.0.xsd">

    <profiles>
        <profile>
            <id>expedia-artifactory</id>
            <repositories>
                <repository>
                    <id>central</id>
                    <url>https://artylab.expedia.biz/public-maven-virtual</url>
                    <snapshots>
                        <enabled>false</enabled>
                    </snapshots>
                </repository>
            </repositories>
            <pluginRepositories>
                <pluginRepository>
                    <id>central</id>
                    <url>https://artylab.expedia.biz/public-maven-virtual</url>
                    <snapshots>
                        <enabled>false</enabled>
                    </snapshots>
                </pluginRepository>
            </pluginRepositories>
        </profile>
    </profiles>

    <activeProfiles>
        <activeProfile>expedia-artifactory</activeProfile>
    </activeProfiles>

    <servers>
        <server>
            <id>central</id>
            <username>${env.ARTIFACTORY_USERNAME}</username>
            <password>${env.ARTIFACTORY_TOKEN}</password>
        </server>
    </servers>

    <mirrors>
        <mirror>
            <id>expedia-mirror</id>
            <name>Expedia Artifactory Mirror</name>
            <url>https://artylab.expedia.biz/public-maven-virtual</url>
            <mirrorOf>*</mirrorOf>
        </mirror>
    </mirrors>
</settings>

